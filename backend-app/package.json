{
  "name": "backend-app",
  "version": "0.1.0",
  "bin": {
    "backend-app": "bin/backend-app.js"
  },
  "scripts": {
    "build": "tsc",
    "bootstrap": "cdk bootstrap",
    "diff:prod": "cdk diff 'prod/*'",
    "deploy:prod": "STAGE=prod cdk deploy 'prod/*'",
    "deploy:prod:watch": "STAGE=prod cdk deploy 'prod/*' --watch",
    "destroy:prod": "STAGE=prod cdk destroy 'prod/*'",
    "test:prompts": "promptfoo eval -c promptfooconfig-prompt.yaml",
    "test:modelConfig": "promptfoo eval -c promptfooconfig-model-config.yaml",
    "test:prompts:watch": "promptfoo eval --watch",
    "test:prompts:view": "promptfoo view",
    "test:prompts:share": "promptfoo share",
    "watch": "tsc -w",
    "test": "jest",
    "synth:prod": "cdk synth 'prod/*'",
    "cdk": "cdk",
    "synth:prod:template": "STAGE=prod npx cdk synth --parameters CustomerIdentifier=abc123 --parameters ProductCode=my-product --parameters AdminEmail=admin@example.com --no-staging --quiet"
  },
  "devDependencies": {
    "@aws-cdk/aws-scheduler-alpha": "^2.186.0-alpha.0",
