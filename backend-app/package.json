    "@types/node": "22.7.9",
    "@types/smartystreets-javascript-sdk": "^5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "aws-cdk": "^2.1023.0",
    "esbuild": "^0.23.0",
    "eslint": "8.57.1",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "promptfoo": "^0.116.7",
    "sharp": "^0.34.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.758.0",
